# --- Swift / Xcode ---
# XcodeGen 產生的 xcodeproj（以 project.yml 為準）
*.xcodeproj/

# Xcode 個人設定
xcuserdata/
*.xcworkspace/xcuserdata/
*.xcuserdatad/
*.xccheckout/
*.bundle/

# 編譯產物
.build/
DerivedData/
*.ipsw
*.xcresult

# --- SwiftPM ---
# Xcode 為 Package 產生的本機狀態（workspace、UI state、scheme 等），整個忽略
.swiftpm/

# --- macOS ---
# 系統產生的垃圾檔
.DS_Store
*.swp
*.lock

# --- CI/CD & Security ---
# 如果你有金鑰或測試用的密鑰，記得也加在這裡
*.env
